# ─────────────────────────────────────────────────────────────────────────────
# AI Smart Attendance System — Backend Environment Configuration Example
#
# Copy this file to `backend/.env` and fill in real values before starting
# the backend for the first time.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB — REQUIRED
# The Mongo connection URL. Include auth credentials & database host here.
MONGO_URL="mongodb://localhost:27017"

# MongoDB — REQUIRED
# The database name the app will use.
DB_NAME="attendance_db"

# CORS — REQUIRED (comma-separated list, or "*" for demo)
# In production you should pin this to your frontend origin(s).
CORS_ORIGINS="*"

# JWT Secret — REQUIRED
# A long random string used to sign session tokens. Never commit this file
# with a real value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="replace-with-a-long-random-string"

# ─────────────────────────────────────────────────────────────────────────────
# First-Run Admin Seeding — REQUIRED (only used on first boot with an empty DB)
#
# On the very first startup, the backend will create ONE admin account using
# the values below. On every subsequent boot these variables are ignored.
# Requirements for SEED_ADMIN_PASSWORD:
#   • At least 8 characters
#   • Contains at least one letter AND one digit
#   • Must NOT be one of: admin123, student123, password, password1, 12345678
# The admin will be forced to change this password on first login.
# ─────────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@yourcollege.edu"
SEED_ADMIN_PASSWORD="ChangeThis#Adm1nPass2026"
# Optional friendly display name.
SEED_ADMIN_NAME="System Administrator"

# ─────────────────────────────────────────────────────────────────────────────
# Face Recognition — Optional
# Cosine/Euclidean distance threshold below which two 128-D face descriptors
# are considered the same person. Lower = stricter. Default 0.55 works well
# for face-api.js browser-generated descriptors.
# ─────────────────────────────────────────────────────────────────────────────
FACE_MATCH_THRESHOLD="0.55"
